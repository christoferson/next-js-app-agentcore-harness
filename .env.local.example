# Copy to .env.local and fill in your values. .env.local is gitignored.
# All config is env-driven (SPEC §8).

# AWS region for all AgentCore clients (single region — SPEC §2).
AWS_REGION=us-east-1

# Local AWS credentials profile. For SSO, run `aws sso login --profile <profile>`
# first, then set the profile here.
AWS_PROFILE=your-profile-name

# Actor identity seed (SPEC §8/§9 auth seam). NEXT_PUBLIC_ so the browser can
# scope sessions/memory to the actor; replace with real auth (Cognito/OIDC) later.
NEXT_PUBLIC_DEFAULT_ACTOR_ID=default-user

# Debug: log AgentCore payloads to the server console for verification. Logs the
# STRUCTURAL InvokeHarness events ([invoke] — block starts/stops, tool results,
# message stop, metadata) plus a count summary of the high-volume text/tool-input
# deltas, and the raw ListEvents output ([ops:raw ListEvents]). Leave unset in
# normal use. Set to 1 to enable.
# AGENTCORE_DEBUG_STREAM=1
